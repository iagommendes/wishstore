{%- comment -%}
  Renders a technical specs table for Wishstore PDP.
  Priority:
  1. product.metafields.custom.specifications (multi-line "Label: Value")
  2. Built-in product facts (vendor, type, sku, weight, barcode, tags)
{%- endcomment -%}

{%- liquid
  assign specs_raw = product.metafields.custom.specifications.value | default: product.metafields.custom.specifications
  assign has_custom_specs = false
  assign parsed_rows = 0
  if specs_raw != blank
    assign has_custom_specs = true
  endif
-%}

<div class="ws-specs__wrap">
  {%- if has_custom_specs -%}
    <table class="ws-specs__table">
      <caption class="visually-hidden">{{ product.title | escape }} — especificações técnicas</caption>
      <tbody>
        {%- assign lines = specs_raw | newline_to_br | split: '<br />' -%}
        {%- for line in lines -%}
          {%- assign clean = line | strip_html | strip -%}
          {%- if clean contains ':' -%}
            {%- assign parts = clean | split: ':' -%}
            {%- assign label = parts | first | strip -%}
            {%- assign value = clean | remove_first: label | remove_first: ':' | strip -%}
            {%- if label != blank and value != blank -%}
              {%- assign parsed_rows = parsed_rows | plus: 1 -%}
              <tr>
                <th scope="row">{{ label | escape }}</th>
                <td>{{ value | escape }}</td>
              </tr>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </tbody>
    </table>
    {%- if parsed_rows == 0 -%}
      <p class="ws-specs__empty">
        Metafield <code>custom.specifications</code> presente, mas sem linhas no formato Label: Value.
      </p>
    {%- endif -%}
  {%- else -%}
    <table class="ws-specs__table">
      <caption class="visually-hidden">{{ product.title | escape }} — dados do produto</caption>
      <tbody>
        {%- if product.vendor != blank -%}
          <tr>
            <th scope="row">Fabricante</th>
            <td>{{ product.vendor | escape }}</td>
          </tr>
        {%- endif -%}
        {%- if product.type != blank -%}
          <tr>
            <th scope="row">Categoria</th>
            <td>{{ product.type | escape }}</td>
          </tr>
        {%- endif -%}
        {%- if product.selected_or_first_available_variant.sku != blank -%}
          <tr>
            <th scope="row">SKU</th>
            <td>{{ product.selected_or_first_available_variant.sku | escape }}</td>
          </tr>
        {%- endif -%}
        {%- if product.selected_or_first_available_variant.barcode != blank -%}
          <tr>
            <th scope="row">Barcode</th>
            <td>{{ product.selected_or_first_available_variant.barcode | escape }}</td>
          </tr>
        {%- endif -%}
        {%- if product.selected_or_first_available_variant.weight > 0 -%}
          <tr>
            <th scope="row">Peso</th>
            <td>
              {{ product.selected_or_first_available_variant.weight | weight_with_unit: product.selected_or_first_available_variant.weight_unit }}
            </td>
          </tr>
        {%- endif -%}
        {%- if product.tags.size > 0 -%}
          <tr>
            <th scope="row">Tags</th>
            <td>{{ product.tags | join: ', ' | escape }}</td>
          </tr>
        {%- endif -%}
      </tbody>
    </table>
    <p class="ws-specs__empty">
      Para uma ficha técnica completa, preencha o metafield
      <code>custom.specifications</code>
      (uma linha por especificação, no formato Label: Value).
    </p>
  {%- endif -%}
</div>
